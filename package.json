{
  "name": "chattering",
  "version": "1.0.0",
  "description": "Unified multi-platform chat client for streamers",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "lint": "eslint src --ext .js",
    "typecheck": "echo 'No TypeScript in this project'"
  },
  "dependencies": {
    "tmi.js": "^1.8.5",
    "tiktok-live-connector": "^1.1.9",
    "youtube-chat": "^2.0.2",
    "electron-store": "^8.1.0",
    "ws": "^8.18.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.1"
  },
  "build": {
    "appId": "com.chattering.app",
    "productName": "Chattering",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icons/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icons/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icons/icon.icns"
    }
  },
  "trustedDependencies": [
    "es5-ext",
    "protobufjs"
  ]
}
